<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <header class="header">
        <div class="container header-inner">
            <a href="/" class="logo">Tech<span>Shop</span></a>
            <nav class="nav">
                <a href="/admin">Главная</a>
                <% if (user.role === 'owner') { %>
                    <a href="/admin/users">Пользователи</a>
                <% } %>
                <% if (user.role === 'owner' || user.role === 'warehouse_manager') { %>
                    <a href="/admin/products">Товары</a>
                <% } %>
                <% if (user.role === 'owner' || user.role === 'orders_manager') { %>
                    <a href="/admin/orders">Заказы</a>
                <% } %>
                <a href="/admin/profile">Профиль</a>
                <a href="/admin/logout">Выход</a>
            </nav>
        </div>
    </header>
    
    <main class="main">
        <div class="container">
            <div class="profile-form">
                <h1>Настройки профиля</h1>
                
                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>
                
                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>
                
                <form method="POST" action="/admin/profile/update">
                    <div class="form-group">
                        <label>Логин</label>
                        <input type="text" value="<%= user.username %>" disabled>
                    </div>
                    <div class="form-group">
                        <label>ФИО</label>
                        <input type="text" name="full_name" value="<%= user.fullName %>" required>
                    </div>
                    <hr style="margin: 25px 0; border: none; border-top: 1px solid #e2e8f0;">
                    <h3 style="margin-bottom: 20px;">Смена пароля</h3>
                    <div class="form-group">
                        <label>Текущий пароль</label>
                        <input type="password" name="currentPassword">
                    </div>
                    <div class="form-group">
                        <label>Новый пароль</label>
                        <input type="password" name="newPassword">
                    </div>
                    <button type="submit" class="btn btn-block">Сохранить</button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
