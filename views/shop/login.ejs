<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <a href="/" class="logo">Tech<span>Shop</span></a>
            </div>
            <h1>Вход</h1>
            
            <% if (error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            
            <form method="POST" action="/login">
                <div class="form-group">
                    <label for="login">Email или логин</label>
                    <input type="text" id="login" name="login" required autofocus placeholder="Email или логин">
                </div>
                
                <div class="form-group">
                    <label for="password">Пароль</label>
                    <input type="password" id="password" name="password" required>
                </div>
                
                <button type="submit" class="btn btn-block">Войти</button>
            </form>
            
            <div class="auth-footer">
                <p>Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
                <a href="/">← Вернуться в магазин</a>
            </div>
        </div>
    </div>
</body>
</html>
